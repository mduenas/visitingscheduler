<?xml version="1.0" encoding="utf-8"?>
<!--
    HIPAA Compliance: Data Extraction Rules

    This file controls what data can be backed up by Android's cloud backup
    and device-to-device transfer features.

    For HIPAA compliance, we exclude:
    - Authentication tokens and credentials
    - Any cached PHI (Protected Health Information)
    - Database files containing patient data
    - Encryption keys
-->
<data-extraction-rules>

    <!-- Cloud backup rules (Android 12+) -->
    <cloud-backup>
        <!-- Exclude sensitive data from cloud backup -->
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="." />
        <exclude domain="external" path="." />

        <!-- Only allow non-sensitive preferences -->
        <include domain="sharedpref" path="app_settings.xml" />
        <include domain="sharedpref" path="ui_preferences.xml" />
    </cloud-backup>

    <!-- Device-to-device transfer rules -->
    <device-transfer>
        <!-- Exclude all data from device transfer -->
        <!-- User must re-authenticate on new device for security -->
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="." />
        <exclude domain="external" path="." />

        <!-- Allow only UI preferences to transfer -->
        <include domain="sharedpref" path="ui_preferences.xml" />
    </device-transfer>

</data-extraction-rules>
